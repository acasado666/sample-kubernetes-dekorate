[{
  "apiVersion" : "apps/v1",
  "kind" : "Deployment",
  "metadata" : {
    "annotations" : {
      "app.dekorate.io/vcs-url" : "https://github.com/acasado666/sample-kubernetes-dekorate.git",
      "app.dekorate.io/commit-id" : "4fc8410c044a4ea4644188d3066ed24f5a5bd2ac"
    },
    "labels" : {
      "app.kubernetes.io/name" : "my-spring-app",
      "app.kubernetes.io/version" : "1.0.0"
    },
    "name" : "my-spring-app"
  },
  "spec" : {
    "replicas" : 2,
    "selector" : {
      "matchLabels" : {
        "app.kubernetes.io/version" : "1.0.0",
        "app.kubernetes.io/name" : "my-spring-app"
      }
    },
    "template" : {
      "metadata" : {
        "annotations" : {
          "app.dekorate.io/vcs-url" : "https://github.com/acasado666/sample-kubernetes-dekorate.git",
          "app.dekorate.io/commit-id" : "4fc8410c044a4ea4644188d3066ed24f5a5bd2ac"
        },
        "labels" : {
          "app.kubernetes.io/version" : "1.0.0",
          "app.kubernetes.io/name" : "my-spring-app"
        }
      },
      "spec" : {
        "containers" : [ {
          "env" : [ {
            "name" : "KUBERNETES_NAMESPACE",
            "valueFrom" : {
              "fieldRef" : {
                "fieldPath" : "metadata.namespace"
              }
            }
          }, {
            "name" : "SPRING_PROFILES_ACTIVE",
            "value" : "prod"
          } ],
          "image" : "acasa/my-spring-app:1.0.0",
          "imagePullPolicy" : "IfNotPresent",
          "name" : "my-spring-app",
          "ports" : [ {
            "containerPort" : 8080,
            "name" : "http",
            "protocol" : "TCP"
          } ]
        } ]
      }
    }
  }
},{
  "apiVersion" : "v1",
  "kind" : "Service",
  "metadata" : {
    "annotations" : {
      "app.dekorate.io/vcs-url" : "https://github.com/acasado666/sample-kubernetes-dekorate.git",
      "app.dekorate.io/commit-id" : "4fc8410c044a4ea4644188d3066ed24f5a5bd2ac"
    },
    "labels" : {
      "app.kubernetes.io/name" : "my-spring-app",
      "app.kubernetes.io/version" : "1.0.0"
    },
    "name" : "my-spring-app"
  },
  "spec" : {
    "ports" : [ {
      "name" : "http",
      "port" : 80,
      "protocol" : "TCP",
      "targetPort" : 8080
    } ],
    "selector" : {
      "app.kubernetes.io/name" : "my-spring-app",
      "app.kubernetes.io/version" : "1.0.0"
    },
    "type" : "ClusterIP"
  }
}]