[{
  "apiVersion" : "apps/v1",
  "kind" : "Deployment",
  "metadata" : {
    "annotations" : {
      "app.dekorate.io/vcs-url" : "https://github.com/acasado666/sample-kubernetes-dekorate.git",
      "app.dekorate.io/commit-id" : "69e9b8b608de2cfdfdd93f1725631f199f2c207d"
    },
    "labels" : {
      "app.kubernetes.io/name" : "my-spring-app",
      "app.kubernetes.io/version" : "1.0.0"
    },
    "name" : "my-spring-app"
  },
  "spec" : {
    "replicas" : 1,
    "selector" : {
      "matchLabels" : {
        "app.kubernetes.io/version" : "1.0.0",
        "app.kubernetes.io/name" : "my-spring-app"
      }
    },
    "template" : {
      "metadata" : {
        "annotations" : {
          "app.dekorate.io/vcs-url" : "https://github.com/acasado666/sample-kubernetes-dekorate.git",
          "app.dekorate.io/commit-id" : "69e9b8b608de2cfdfdd93f1725631f199f2c207d"
        },
        "labels" : {
          "app.kubernetes.io/version" : "1.0.0",
          "app.kubernetes.io/name" : "my-spring-app"
        }
      },
      "spec" : {
        "containers" : [ {
          "env" : [ {
            "name" : "KUBERNETES_NAMESPACE",
            "valueFrom" : {
              "fieldRef" : {
                "fieldPath" : "metadata.namespace"
              }
            }
          } ],
          "image" : "acasa/my-spring-app:1.0.0",
          "imagePullPolicy" : "IfNotPresent",
          "livenessProbe" : {
            "httpGet" : {
              "path" : "/actuator/health/liveness",
              "port" : 8080,
              "scheme" : "HTTP"
            },
            "successThreshold" : 1
          },
          "name" : "my-spring-app",
          "readinessProbe" : {
            "httpGet" : {
              "path" : "/actuator/health/readiness",
              "port" : 8080,
              "scheme" : "HTTP"
            }
          }
        } ]
      }
    }
  }
}]